rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // users/{uid}
    // =========================================================
    match /users/{userId} {

      // A user can only read their OWN document
      allow read: if request.auth != null && request.auth.uid == userId;

      // A user can CREATE their own document (on first login)
      allow create: if request.auth != null
        && request.auth.uid == userId;

      // A user can UPDATE their own document BUT cannot touch
      // sensitive fields that are only set by the backend (Admin SDK).
      // The Admin SDK bypasses all security rules, so it can still
      // update these fields freely from the backend webhook.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'membershipStatus',
          'membershipPurchaseDate',
          'stripeSessionId',
          'stripeCustomerId',
          'role'
        ]);

      // No client-side deletes allowed
      allow delete: if false;

      // =========================================================
      // users/{uid}/bookings — subcollection
      // =========================================================
      match /bookings/{bookingId} {
        // User can read their own bookings
        allow read: if request.auth != null && request.auth.uid == userId;

        // No client-side writes — bookings are created by the backend
        // webhook only (Admin SDK bypasses these rules)
        allow write: if false;
      }
    }

    // =========================================================
    // chats/{uid} — Concierge Chat
    // =========================================================
    match /chats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['text', 'senderId', 'createdAt'])
          && request.resource.data.senderId == userId;
        allow update, delete: if false;
      }
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
